title **Figure 6.** Shapley Additive exPlanations (SHAP) Decomposition Pipeline\n<i>From model prediction to human-readable feature attribution</i>

skinparam rectangle {
  BackgroundColor<<model>> #FFF3E0
  BorderColor<<model>> #E65100
  BackgroundColor<<shap>> #FCE4EC
  BorderColor<<shap>> #C62828
  BackgroundColor<<viz>> #F3E5F5
  BorderColor<<viz>> #6A1B9A
}

rectangle "**Trained GCN Model**" as M <<model>> {
  card "f(x) = P(malicious | features)" as fx
}

rectangle "**SHAP TreeExplainer**" as SE <<shap>> {
  card "For each feature xᵢ:" as each
  card "Enumerate all subsets\nS ⊆ N \\ {i}" as subsets
  card "Compute marginal\ncontribution:\nf(S ∪ {i}) − f(S)" as marginal
  card "Weight by coalition\nprobability:\n|S|! (|N|−|S|−1)! / |N|!" as weight
  card "Sum → φᵢ" as sum
  
  each --> subsets
  subsets --> marginal
  marginal --> weight
  weight --> sum
}

rectangle "**Attribution Output**" as AO <<shap>> {
  card "φ₁ = +0.25 (Packet Var)" as p1
  card "φ₂ = +0.18 (Betti-1)" as p2
  card "φ₃ = +0.12 (Entropy)" as p3
  card "φ₄ = −0.04 (Latency)" as p4
  card "φ₅ = −0.01 (Port)" as p5
}

rectangle "**React Waterfall Visualisation**" as VIZ <<viz>> {
  card "Base value: E[f(X)] = 0.15" as base
  card "████████████████ +0.25 ↑" as bar1
  card "████████████ +0.18 ↑" as bar2
  card "████████ +0.12 ↑" as bar3
  card "██ −0.04 ↓" as bar4
  card "█ −0.01 ↓" as bar5
  card "**f(x) = 0.88  →  MALICIOUS**" as final
}

M --> SE : "flagged\ntransaction"
SE --> AO : "per-feature\nShapley values"
AO --> VIZ : "render in\nReact dashboard"

